🧪 Testing MVI

@Test
fun `should emit loading then success`() = runTest {

    viewModel.onIntent(PostIntent.LoadPosts)

    val states = viewModel.state.take(2).toList()

    assertTrue(states[0].isLoading)
    assertTrue(states[1].posts.isNotEmpty())
}

