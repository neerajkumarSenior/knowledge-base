📦 Step 1: Define Intent

Intent = User action

sealed interface PostIntent {

    data object LoadPosts : PostIntent

    data class CreatePost(
        val title: String,
        val body: String
    ) : PostIntent

    data object Refresh : PostIntent
}

👉 Intent सिर्फ user actions represent करता है
👉 Business logic नहीं

---

📦 Step 2: Define State

Single immutable state

data class PostState(
    val posts: List<Post> = emptyList(),
    val isLoading: Boolean = false,
    val error: String? = null
)

---

📦 Step 3: ViewModel (MVI Style)

class PostViewModel(
    private val getPostsUseCase: GetPostsUseCase,
    private val createPostUseCase: CreatePostUseCase
) : ViewModel() {

    private val _state = MutableStateFlow(PostState())
    val state = _state.asStateFlow()

    fun onIntent(intent: PostIntent) {
        when (intent) {

            PostIntent.LoadPosts -> loadPosts()

            is PostIntent.CreatePost -> createPost(
                intent.title,
                intent.body
            )

            PostIntent.Refresh -> loadPosts()
        }
    }

    private fun loadPosts() {
        viewModelScope.launch {

            _state.update { it.copy(isLoading = true) }

            try {
                val posts = getPostsUseCase()

                _state.update {
                    it.copy(
                        posts = posts,
                        isLoading = false,
                        error = null
                    )
                }

            } catch (e: Exception) {

                _state.update {
                    it.copy(
                        isLoading = false,
                        error = e.message
                    )
                }
            }
        }
    }

    private fun createPost(title: String, body: String) {
        viewModelScope.launch {
            createPostUseCase(title, body)
            loadPosts()
        }
    }
}

