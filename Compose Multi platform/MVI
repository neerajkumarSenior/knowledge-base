🧠 Reducer Pattern (Advanced MVI)

Production-ready MVI में reducer use होता है।

---

Step 1: Define Action

sealed interface PostAction {
    data object Loading : PostAction
    data class Success(val posts: List<Post>) : PostAction
    data class Error(val message: String?) : PostAction
}

---

Step 2: Reducer Function

private fun reduce(
    oldState: PostState,
    action: PostAction
): PostState {

    return when (action) {

        PostAction.Loading -> {
            oldState.copy(isLoading = true)
        }

        is PostAction.Success -> {
            oldState.copy(
                posts = action.posts,
                isLoading = false,
                error = null
            )
        }

        is PostAction.Error -> {
            oldState.copy(
                isLoading = false,
                error = action.message
            )
        }
    }
}

---

Step 3: Dispatch Action

private fun dispatch(action: PostAction) {
    _state.update { old ->
        reduce(old, action)
    }
}

